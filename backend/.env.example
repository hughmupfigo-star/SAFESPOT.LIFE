# SAFE Story Intelligence API — Environment Configuration

# Claude API Key
# Get from: https://console.anthropic.com
# Keep this SECRET — never commit to version control
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (if deploying to production)
CORS_ORIGIN=https://yourdomain.com

# Database Configuration (optional, for future use)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=safe_stories
# DB_USER=user
# DB_PASSWORD=password

# Email Configuration (for sending reports)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=stories@safespot.life
# SMTP_PASSWORD=your_password

# Formspree Configuration
# FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
# FORMSPREE_SECRET=your_webhook_secret
